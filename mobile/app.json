{
  "expo": {
    "name": "AIS",
    "slug": "ais-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "ais",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0E0E12",
    "splash": {
      "backgroundColor": "#0E0E12"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0E0E12"
      },
      "package": "com.ais.app"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "newArchEnabled": false
  }
}
